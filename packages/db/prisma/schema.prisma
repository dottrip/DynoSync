// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users table (synced with Supabase Auth)
model User {
  id              String       @id @default(uuid())
  email           String       @unique
  username        String?      @unique
  tier            String       @default("free") // "free" | "pro" | "elite"
  region          String       @default("na")   // "global" | "na" | "eu" | "asia"
  avatarUrl       String?      @map("avatar_url")
  instagramHandle String?      @map("instagram_handle")
  discordId       String?      @map("discord_id")
  pushToken       String?      @map("push_token")
  aiCreditsUsed   Int          @default(0) @map("ai_credits_used")
  aiCreditsResetAt DateTime    @default(now()) @map("ai_credits_reset_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  vehicles        Vehicle[]
  follows         BuildFollow[]
  feedbacks       Feedback[]
  advisorLogs     AdvisorLog[]
  aiCreditLogs    AiCreditLog[]

  @@map("users")
}

// Vehicles table
model Vehicle {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  make               String
  model              String
  year               Int
  trim               String?
  drivetrain         String?   // "FWD" | "RWD" | "AWD"
  imageUrl           String?   @map("image_url")
  isArchived         Boolean   @default(false) @map("is_archived")
  isPublic           Boolean   @default(false) @map("is_public")
  advisorCacheKey    String?   @map("advisor_cache_key")
  lastAdvisorResult  Json?     @map("last_advisor_result")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dynoRecords        DynoRecord[]
  modLogs            ModLog[]
  followers          BuildFollow[]
  advisorLogs        AdvisorLog[]

  @@index([userId])
  @@index([userId, isArchived])
  @@map("vehicles")
}

// Dyno records table
model DynoRecord {
  id           String    @id @default(uuid())
  vehicleId    String    @map("vehicle_id")
  whp          Float     // Wheel horsepower
  torqueNm     Float?    @map("torque_nm") // Torque in Newton-meters
  zeroToSixty  Float?    @map("zero_to_sixty") // 0-60 mph time in seconds
  quarterMile  Float?    @map("quarter_mile") // 1/4 mile time in seconds
  notes        String?   @db.Text
  recordedAt   DateTime  @default(now()) @map("recorded_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([vehicleId, recordedAt])
  @@map("dyno_records")
}

// Mod logs table (modification history)
model ModLog {
  id          String    @id @default(uuid())
  vehicleId   String    @map("vehicle_id")
  category    String    // "engine" | "exhaust" | "intake" | "suspension" | "brakes" | "wheels" | "aero" | "interior" | "electronics" | "other"
  description String    @db.Text
  cost        Float?    // Cost in USD
  installedAt DateTime  @default(now()) @map("installed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([vehicleId, installedAt])
  @@map("mod_logs")
}

// Build followers table
model BuildFollow {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  vehicleId String   @map("vehicle_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([userId, vehicleId])
  @@index([userId])
  @@index([vehicleId])
  @@map("build_follows")
}

// Feedback table
model Feedback {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   // "bug", "feature", "other"
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feedback")
}

// AI advisor analysis logs
model AdvisorLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @map("user_id")
  vehicleId  String   @map("vehicle_id")
  whp        Int
  torque     Int
  torqueUnit String   @map("torque_unit")
  advice     String   @db.Text
  suggestion Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("advisor_logs")
}

// AI credit usage logs
model AiCreditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id")
  feature   String   // "advisor_quick", "advisor_deep", "ocr_scan", "ocr_vin", "baseline_specs"
  credits   Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ai_credit_logs")
}
